{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NebulaDisplay Viewer",
  "version": "0.1.0",
  "identifier": "io.nebuladisplay.viewer.desktop",
  "build": {
    "frontendDist": "../../web/dist/view",
    "beforeBuildCommand": "cd ../web && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "NebulaDisplay Viewer",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
