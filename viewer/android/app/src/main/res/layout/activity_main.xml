<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#0b0f14">

    <SurfaceView
        android:id="@+id/stream_surface"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/connect_pane"
        android:orientation="vertical" android:gravity="center"
        android:padding="32dp"
        android:layout_width="match_parent" android:layout_height="match_parent">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/app_name" android:textSize="28sp" android:textColor="#e8eef5"
            android:layout_marginBottom="24dp" />
        <EditText android:id="@+id/host" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="@string/hint_host"
            android:inputType="textUri" android:textColor="#e8eef5" android:textColorHint="#93a4b5" />
        <EditText android:id="@+id/pin" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="@string/hint_pin"
            android:inputType="number" android:textColor="#e8eef5" android:textColorHint="#93a4b5" />
        <Button android:id="@+id/connect" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="@string/connect"
            android:layout_marginTop="16dp" />
        <TextView android:id="@+id/status" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textColor="#ff6b6b"
            android:layout_marginTop="12dp" />
    </LinearLayout>
</FrameLayout>
